{
  "name": "friends-of-all-saloon",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "autoprefixer": "^10.4.21",
    "lucide-react": "^0.513.0",
    "postcss": "^8.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.12",
    "eslint": "^8.57.1",
    "typescript": "~4.9.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:ci": "react-scripts test --watchAll=false --ci",
    "lint": "eslint \"src/**/*.{js,jsx}\" --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "audit:ci": "npm audit --audit-level=high",
    "ci": "npm run audit:ci && npm run lint && npm run typecheck && npm run test:ci && npm run build",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "overrides": [
      {
        "files": [
          "**/*.test.js",
          "**/setupTests.js"
        ],
        "rules": {
          "testing-library/no-node-access": "off"
        }
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "@tootallnate/once": "3.0.1",
    "nth-check": "2.1.1",
    "react-scripts": {
      "resolve-url-loader": {
        "postcss": "8.5.4"
      }
    },
    "serialize-javascript": "7.0.5",
    "underscore": "1.13.8",
    "webpack-dev-server": "5.2.3"
  }
}
